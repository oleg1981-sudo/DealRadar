# ── DealRadar environment ─────────────────────────────────────────────────────
# Copy to .env.local. The app runs WITHOUT any of these (mock providers + no
# persistence) — fill in as your applications get approved.

# ── Supabase (system of record for deals) ────────────────────────────────────
# Create a free project at https://supabase.com → Project Settings → API.
# Then run supabase/schema.sql in the SQL editor.
SUPABASE_URL=
# Service-role key — SERVER ONLY, bypasses RLS. Never expose with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ── Upstash Redis (30-min API response cache) ────────────────────────────────
# Create a free database at https://upstash.com → REST API section.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Price providers ──────────────────────────────────────────────────────────
# Kelkoo Group (PRIMARY) — publisher sign-up at https://www.kelkoogroup.com.
# After approval: Publisher Center → Account → API Token → Create new token.
# Tokens are per-country; start with your main market.
KELKOO_API_TOKEN=

# AWIN (SECONDARY) — publisher sign-up at https://www.awin.com (small refundable
# deposit). AWIN serves a combined PRODUCT FEED (gzipped CSV), not a search API,
# so it is INGESTED on a schedule, not queried per request: set AWIN_FEED_URL to
# the datafeed download URL (Toolbox → Create-a-Feed) and run
#   node scripts/ingest-awin.cjs --upsert
# from a cron/Action. Leave unset to use mock data. SECRET: the URL embeds your
# AWIN API key — never commit it; rotate the key if it leaks.
AWIN_FEED_URL=

# Tradedoubler (TERTIARY) — publisher sign-up at https://www.tradedoubler.com.
# Token: My Account → Manage Tokens (Products REST API).
TRADEDOUBLER_TOKEN=

# Strackr — multi-network affiliate data aggregator integration.
STRACKR_API_KEY=

# Idealo — NO self-service API exists for comparison publishers. The provider
# stays mock until a negotiated data partnership: https://www.idealo.de/partner
IDEALO_API_KEY=

# ── Cron & Webhook protection ────────────────────────────────────────────────
# Any long random string. The refresh job must send it as
# "Authorization: Bearer <CRON_SECRET>" to POST /api/refresh.
CRON_SECRET=
# Webhook secret query parameter for incoming affiliate postbacks (/api/postbacks?secret=...)
WEBHOOK_SECRET=

# ── Email (price-drop alerts) ────────────────────────────────────────────────
# Resend (https://resend.com) API key. Without it, alert subscriptions are still
# captured (and persisted if Supabase is set) but no email is sent — the message
# is logged server-side instead. The refresh job sends queued alerts.
RESEND_API_KEY=
# Verified sender, e.g. "DealRadar <alerts@yourdomain.com>". Defaults to Resend's
# test sender (onboarding@resend.dev), which works without domain verification.
ALERT_FROM_EMAIL=
